# ============================================
# LiTree Lab Studio — Environment Variables
# ============================================

# JWT signing secret (generate: openssl rand -hex 32)
AUTH_SECRET=

# Admin account credentials
ADMIN_EMAIL=
ADMIN_PASSWORD_HASH=
ADMIN_NAME=

# API Backend URL
NEXT_PUBLIC_API_BASE=https://api.litlabs.net
NEXT_PUBLIC_SITE_URL=https://litlabs.net

# Clerk Configuration
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

# ============================================
# Stripe Payment Configuration
# ============================================

# Stripe secret key (from https://dashboard.stripe.com/apikeys)
# This is the sk_live_... key — keep it secret, never commit to git
STRIPE_SECRET_KEY=

# Stripe publishable key (pk_live_...) — safe for frontend
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# Stripe webhook secret (whsec_...) — from your webhook endpoint settings
STRIPE_WEBHOOK_SECRET=

# Stripe price IDs
STRIPE_PRO_PRICE_ID=

# ============================================
# AI Model Configuration
# ============================================

OPENROUTER_API_KEY=
GEMINI_API_KEY=
GOOGLE_API_KEY=
OPENROUTER_MODEL=google/gemini-2.5-flash

# ============================================
# Clerk Webhook Secret
CLERK_WEBHOOK_SECRET=

# Discord Webhook (for Jarvis notifications)
DISCORD_WEBHOOK_URL=
JARVIS_WEBHOOK_URL=

# ============================================
# Additional AI Provider Keys
# ============================================
# Additional AI Provider Keys
# ============================================
HUGGING_FACE_API_KEY=
TOGETHER_API_KEY=
FAL_KEY=
MINIMAX_API_KEY=
SKYBOX_API_KEY=

# ============================================
# Cloudflare R2 Storage
# ============================================
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
