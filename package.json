{
  "name": "frontend",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "test": "node --test tests/unit/*.test.mjs",
    "test:watch": "node --test --watch tests/unit/*.test.mjs",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "pages:build": "npx @cloudflare/next-on-pages@1",
    "pages:deploy": "npm run pages:build && npx wrangler pages deploy .vercel/output/static",
    "pages:dev": "npx wrangler pages dev .vercel/output/static --compatibility-flags=nodejs_compat"
  },
  "dependencies": {
    "@clerk/nextjs": "^6.39.5",
    "@google/genai": "^2.8.0",
    "@google/generative-ai": "^0.24.1",
    "@rollup/rollup-android-arm64": "^4.62.2",
    "@rollup/wasm-node": "^4.62.2",
    "@stripe/stripe-js": "^5.10.0",
    "@supabase/supabase-js": "^2.106.2",
    "bcryptjs": "^3.0.3",
    "jose": "^6.2.3",
    "keytar": "^7.9.0",
    "lucide-react": "^1.17.0",
    "next": "^16.2.9",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "sharp": "^0.33.0",
    "stripe": "^18.0.0",
    "svix": "^1.95.1"
  },
  "devDependencies": {
    "@jest/globals": "^30.4.1",
    "@netlify/plugin-nextjs": "^5",
    "@playwright/test": "^1",
    "@tailwindcss/postcss": "^4",
    "@testing-library/jest-dom": "^6",
    "@testing-library/react": "^16",
    "@testing-library/user-event": "^14",
    "@types/jest": "^30.0.0",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.6",
    "jest": "^30.4.2",
    "jest-environment-jsdom": "^30.4.1",
    "jsdom": "^25",
    "tailwindcss": "^4",
    "ts-jest": "^29.4.11",
    "typescript": "^5",
    "vitest": "^3"
  }
}
