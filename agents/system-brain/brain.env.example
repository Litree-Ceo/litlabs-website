# LiTTree Brain Config — ~/.config/littree/brain.env
# Copy this file to ~/.config/littree/brain.env and fill in your values

# Discord webhooks (get from Discord Server Settings > Integrations > Webhooks)
DISCORD_SYSTEM_WEBHOOK=
DISCORD_ALERTS_WEBHOOK=

# PC to monitor (Tailscale IP if available, otherwise LAN IP)
MONITOR_PC_IP=192.168.0.77

# Alert thresholds (%)
ALERT_THRESHOLD_DISK=85
ALERT_THRESHOLD_MEM=90